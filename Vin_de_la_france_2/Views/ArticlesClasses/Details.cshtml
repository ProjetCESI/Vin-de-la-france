<button onclick="addToCart(productId, productName, price)">Ajouter au panier</button>

   <script>
       function addToCart(productId, productName, price) {
           fetch('/api/cart/add', {
               method: 'POST',
               headers: {
                   'Content-Type': 'application/json'
               },
               body: JSON.stringify({
                   productId: productId,
                   productName: productName,
                   quantity: 1,
                   price: price
               })
           }).then(response => {
               if (response.ok) {
                   alert('Article ajouté au panier');
               }
           });
       }
   </script>
